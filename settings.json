{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "99",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Edit(~/.claude/**)",
      "Read",
      "Write(~/.claude/**)",
      "Bash(~/.claude/hooks/ways/list-triggered.sh:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(diff:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(pwd:*)",
      "Bash(echo:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",
      "Bash(tee:*)",
      "Bash(uname:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(test:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(ln:*)",
      "Bash(touch:*)",
      "Bash(make:*)",
      "Bash(cargo:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(attend:*)",
      "Bash(ways:*)",
      "Bash(ps:*)",
      "Bash(sha256sum:*)",
      "Bash(python3:*)",
      "Bash(env:*)",
      "Bash(id:*)",
      "Bash(date:*)",
      "Bash(sleep:*)",
      "Bash(command:*)",
      "Bash(curl:*)",
      "Bash(sudo:*)",
      "Bash(tar:*)",
      "Bash(printf:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(jq:*)",
      "Bash(adr:*)",
      "Bash(adr-tool:*)",
      "Bash(dotfiles:*)",
      "Bash(mmaid:*)",
      "Bash(kg:*)",
      "Bash(way-embed:*)",
      "Bash(way-match:*)",
      "Bash(attend-chat:*)",
      "Bash(gpg:*)",
      "Bash(gpgconf:*)",
      "Bash(base64:*)",
      "Bash(.claude/**:*)",
      "mcp__knowledge-graph__*",
      "mcp__jira-cloud__*",
      "mcp__chrome-devtools__*",
      "mcp__claude-in-chrome__*",
      "mcp__google-workspace__*",
      "mcp__slack-mcp__*",
      "mcp__thinking-strategies__*",
      "Bash(./dotfiles help)",
      "Bash(./dotfiles status)",
      "Bash(./dotfiles deploy:*)",
      "Bash(./dotfiles capture:*)",
      "Bash(~/.dotfiles/dotfiles status *)",
      "Bash(~/.dotfiles/dotfiles list *)",
      "Bash(~/.dotfiles/dotfiles deploy *)",
      "Bash(~/.dotfiles/dotfiles help *)",
      "Bash(~/.dotfiles/dotfiles capture *)",
      "Read(//usr/share/oh-my-posh/themes/**)",
      "Read(~/**)",
      "Bash(~/.dotfiles/dotfiles add *)",
      "Bash(posh-theme help *)",
      "Bash(posh-theme list *)",
      "Bash(posh-theme current *)",
      "Bash(posh-theme preview *)",
      "Bash(oh-my-posh --help)",
      "Bash(oh-my-posh get *)",
      "WebFetch(domain:ohmyposh.dev)",
      "Bash(oh-my-posh print *)",
      "Bash(oh-my-posh debug *)",
      "Bash(oh-my-posh config *)",
      "Bash(posh-theme fetch *)",
      "Bash(posh-theme preview-all *)",
      "Bash(zsh *)",
      "Bash(oh-my-posh init *)",
      "Bash(/bin/cat)",
      "Bash(/bin/cat -A)",
      "Bash(ssh *)",
      "Bash(sshpass -V)",
      "Bash(glow --version)"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-setup.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/clear-markers.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/check-config-updates.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-state.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/bin/ways init"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/bin/ways corpus --if-stale --quiet"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/clear-markers.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-state.sh"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-state.sh"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/clear-markers.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-state.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/bin/ways init"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-file-pre.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-bash-pre.sh"
          }
        ]
      },
      {
        "matcher": "TaskCreate",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/mark-tasks-active.sh"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-task-pre.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-prompt.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-state.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/inject-subagent.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash|Task",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-post.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Edit|Write|Bash|Task",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-post.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-response.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "${HOME}/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "knowledge-work-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/knowledge-work-plugins"
      }
    }
  },
  "skipWorkflowUsageWarning": true,
  "autoCompactEnabled": false,
  "teammateMode": "auto"
}
