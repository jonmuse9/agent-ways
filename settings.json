{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "99"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Edit(~/.claude/**)",
      "Edit(/home/aaron/.claude/**)",
      "Read",
      "Write(~/.claude/**)",
      "Write(/home/aaron/.claude/**)",
      "Bash(~/.claude/hooks/ways/list-triggered.sh:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(diff:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(pwd:*)",
      "Bash(echo:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",
      "Bash(tee:*)",
      "Bash(uname:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(test:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(ln:*)",
      "Bash(touch:*)",
      "Bash(make:*)",
      "Bash(cargo:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(attend:*)",
      "Bash(ways:*)",
      "Bash(ps:*)",
      "Bash(sha256sum:*)",
      "Bash(python3:*)",
      "Bash(env:*)",
      "Bash(id:*)",
      "Bash(date:*)",
      "Bash(sleep:*)",
      "Bash(command:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-setup.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/clear-markers.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/check-config-updates.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-state.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/bin/ways init"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/bin/ways corpus --if-stale --quiet"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/clear-markers.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-state.sh"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-state.sh"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/clear-markers.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-state.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/bin/ways init"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-file-pre.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-bash-pre.sh"
          }
        ]
      },
      {
        "matcher": "TaskCreate",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/mark-tasks-active.sh"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-task-pre.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-prompt.sh"
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-state.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/inject-subagent.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ways/check-response.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "${HOME}/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "knowledge-work-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/knowledge-work-plugins"
      }
    }
  }
}
