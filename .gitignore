# Ignore everything by default
*

# Track these directories
!.gitignore
!CLAUDE.md
!todo-*.md
!Makefile
!README.md
!LICENSE
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!settings.json
!statusline.sh
!ways.json
!.claude-upstream

# GitHub community health files
!.github/
!.github/FUNDING.yml
!.github/pull_request_template.md
!.github/ISSUE_TEMPLATE/
!.github/ISSUE_TEMPLATE/*.md
!.github/workflows/
!.github/workflows/*.yml

# Agents
!agents/
!agents/*.md

# Commands (slash commands)
!commands/
!commands/*.md

# Skills (semantic discovery)
!skills/
!skills/*/
!skills/*/SKILL.md
!skills/*/*.md

# Documentation
!docs/
!docs/*.md
!docs/architecture/
!docs/architecture/*.yaml
!docs/architecture/*.md
!docs/architecture/*/
!docs/architecture/**/*.md
!docs/design-notes/
!docs/design-notes/*.md
!docs/scripts/
!docs/scripts/*
!docs/hooks-and-ways/
!docs/hooks-and-ways/*.md
!docs/hooks-and-ways/**/
!docs/hooks-and-ways/**/*.md
!docs/attend-and-monitor/
!docs/attend-and-monitor/*.md
!docs/attend-and-monitor/**/
!docs/attend-and-monitor/**/*.md
!docs/images/
!docs/images/*
!docs/observations/
!docs/observations/*.md
!docs/research/
!docs/research/*.md
!docs/reference/
!docs/reference/*/
!docs/reference/**/*.md
!docs/reference/**/*.png

# Hooks and ways
!hooks/
!hooks/*.sh
!hooks/pre-commit
!hooks/ways/
!hooks/ways/*.md
!hooks/ways/*.sh
!hooks/ways/frontmatter-schema.yaml
# ways-corpus.jsonl is generated dynamically by `make setup` — not tracked
# It contains per-user embedding vectors and may include project-local ways
# Nested ways: domain/wayname[/subway...]/way.md + macro.sh + bundled tools
!hooks/ways/*/
!hooks/ways/**/
!hooks/ways/**/*.md
!hooks/ways/**/*.sh
!hooks/ways/**/*.locales.jsonl
!hooks/ways/**/*.yaml.template
!hooks/ways/**/provenance.yaml
!hooks/ways/**/adr-tool
!hooks/ways/**/chart-tool
# Graph tool metadata — generated by Logseq/Obsidian, not tracked
hooks/ways/logseq/
hooks/ways/.obsidian/

# Scripts (shared utilities for hooks, macros, skills)
!scripts/
!scripts/doc-graph.sh
!scripts/install.sh
!scripts/project-pulse
!scripts/test-locales.py
!scripts/attend-demo.sh
!scripts/attend-format-probe.sh
!scripts/hook-fire-detector.sh
!scripts/signal-report.py
!docs/signal-analysis/
!docs/signal-analysis/*.md
!docs/signal-analysis/*.png
!docs/signal-analysis/*.csv

# Governance traceability (separable)
# CLI tools (root symlinks to implementation scripts)
!governance-report
!ways-stats
!embed-status
!embed-corpus
!lint-ways
!governance/
!governance/README.md
!governance/*.py
!governance/*.sh
!governance/policies/
!governance/policies/*.md
!governance/policies/*/
!governance/policies/**/*.md

# Tools (source, tests, build artifacts)
!tools/
!tools/way-match/
!tools/way-match/*
!tools/way-match/snowball/
!tools/way-match/snowball/*
!tools/way-embed/
!tools/way-embed/*
!tools/way-embed/llama.cpp
!tools/mmaid/
!tools/mmaid/*
!tools/agent-fmt/
!tools/agent-fmt/**
!tools/agent-identity/
!tools/agent-identity/**
!tools/sensor-trait/
!tools/sensor-trait/**
!tools/sensor-git/
!tools/sensor-git/**
!tools/sensor-context/
!tools/sensor-context/**
!tools/sensor-peers/
!tools/sensor-peers/**
!tools/sensor-processes/
!tools/sensor-processes/**
!tools/sensor-disclosure/
!tools/sensor-disclosure/**
!tools/ways-cli/
!tools/ways-cli/**
# ways-cli build artifacts (tracked via .gitignore inside ways-cli/)
tools/ways-cli/target/
!tools/attend/
!tools/attend/**
# attend build artifacts
tools/attend/target/
!tools/attend-chat/
!tools/attend-chat/**
# attend-chat build artifacts (workspace target, but listed for clarity)
tools/attend-chat/target/
# Workspace-level Cargo files
!tools/Cargo.toml
!tools/Cargo.lock

# Standalone tools (user-facing CLI utilities)
!tools/
!tools/*

# Models (GGUF weights for embedding inference)
!models/
!models/*

# Built binaries (acquired via `make ways` / GitHub Releases, not committed)
!bin/
bin/ways
bin/way-embed-*

# Tests
!tests/
!tests/*.md
!tests/*/
!tests/**/*.md
!tests/**/*.sh

# Plugin config (not runtime data)
!plugins/
!plugins/config.json
